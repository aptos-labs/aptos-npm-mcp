{
  "name": "@aptos-labs/aptos-mcp",
  "version": "0.0.22",
  "main": "dist/server.js",
  "module": "dist/server.js",
  "bin": {
    "aptos-mcp": "dist/server.js"
  },
  "keywords": [
    "mcp",
    "vibe code",
    "aptos mcp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aptos-labs/aptos-npm-mcp"
  },
  "homepage": "https://github.com/aptos-labs/aptos-npm-mcp/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/aptos-labs/aptos-npm-mcp/issues"
  },
  "license": "Apache-2.0",
  "author": "aptoslabs.com",
  "type": "module",
  "description": "A MCP server for Aptos NPM packages",
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && cp -r src/resources dist/ && chmod +x dist/server.js",
    "start": "npm run build && tsx src/server.ts",
    "dev": "npm run build && fastmcp dev src/server.ts",
    "prepublishOnly": "node ./scripts/inject-client-id.js && npm run build",
    "postpublish": "node ./scripts/restore-client-id.js",
    "lint": "prettier --check . && eslint . && tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write . && eslint --fix ."
  },
  "dependencies": {
    "@aptos-labs/api-gateway-admin-api-client": "^4.2.0",
    "dotenv": "^17.4.2",
    "fastmcp": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.9.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.1",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  }
}
